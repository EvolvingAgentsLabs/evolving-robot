# Copy to .env and fill in. The brain runs on Gemma via Google AI Studio (no GPU).
#
# Primary path: Google AI Studio (generativelanguage API).
#   Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model id served by AI Studio's generateContent. Confirmed working 2026-07-04.
# Note: gemma-4 does "thinking" by default (leaks into text, bills extra tokens).
GEMMA_MODEL=gemma-4-26b-a4b-it

# Fallback path: OpenRouter (also GPU-free). Used when ROBOT_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it

# Which provider the brain uses: "aistudio" (default) or "openrouter".
ROBOT_PROVIDER=aistudio

# httpx read timeout (seconds). gemma-4 "thinking" rewrites can exceed 60s.
GEMMA_TIMEOUT=120

# sim2d ports
SIM_WS_PORT=9091
SIM_HTTP_PORT=9092
